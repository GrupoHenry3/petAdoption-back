generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                    String          @id @default(cuid(2))
  email                 String          @unique
  password              String          @unique
  googleID              String?         @map("google_id")
  fullName              String?         @map("full_name")
  country               String?
  city                  String?
  avatarURL             String?         @map("avatar_url")
  userType              UserType        @default(User) @map("user_type")
  siteAdmin             Boolean         @default(false) @map("site_admin")
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  shelter               Shelter?
  favoritePets          FavoritePets[]
  adoptions             Adoption[]

  @@index([id, email])
  @@map("pa_users")
}

model FavoritePets {
  id                    String          @id @default(cuid(2))
  userID                String          
  user                  User            @relation(fields: [userID], references: [id])
  petID                 String          
  pet                   Pet             @relation(fields: [petID], references: [id])
  createdAt             DateTime        @default(now()) @map("created_at")

  @@index([userID, petID])
  @@map("pa_user_favorites")
}

model Shelter {
  id                    String          @id @default(cuid(2))
  name                  String
  country               String
  state                 String
  city                  String
  address               String
  phoneNumber           String          @map("phone_number")
  website               String
  description           String
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  userID                String          @unique @map("user_id")
  user                  User            @relation(fields: [userID], references: [id])
  pets                  Pet[]
  adoptions             Adoption[]

  @@index([name, country, city, state])
  @@map("pa_shelters")
}

model Pet {
  id                    String          @id @default(cuid(2))
  name                  String
  age                   Int
  gender                PetGender       @default(Male)
  size                  PetSize         @default(Small)
  adoptionFee           Int
  isAdopted             Boolean         @default(false) @map("is_adopted")
  isActive              Boolean         @default(true)
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  shelterID             String          @unique 
  shelter               Shelter         @relation(fields: [shelterID], references: [id])
  breedID               String          @unique
  breed                 PetBreed        @relation(fields: [breedID], references: [id])
  speciesID             String          @unique
  species               PetSpecies      @relation(fields: [speciesID], references: [id])
  adoptionID            String?         @unique
  adoption              Adoption?       @relation(fields: [adoptionID], references: [id])
  favorites             FavoritePets[]

  @@index([name, gender, size, breedID, speciesID])
  @@map("pa_pets")
}

model PetBreed {
  id                    String          @id @default(cuid(2))
  name                  String
  description           String
  avatarURL             String?         @map("avatar_url")
  createdAt             DateTime        @default(now()) @map("created_at")

  pets                  Pet[]
  speciesID             String          @unique
  species               PetSpecies      @relation(fields: [speciesID], references: [id])

  @@index([name])
  @@map("pa_pet_breeds")
}

model PetSpecies {
  id                    String          @id @default(cuid(2))
  name                  String          @unique
  createdAt             DateTime        @default(now()) @map("created_at")

  pets                  Pet[]
  breeds                PetBreed[]

  @@map("pa_pet_species")
}

model Adoption {
  id                    String          @id @default(cuid(2))
  questions             Json?
  status                AdoptionStatus  @default(Pending)
  rejectionStatus       String?
  pets                  Pet[]
  
  userID                String          @unique
  user                  User            @relation(fields: [userID], references: [id])
  shelterID             String          @unique
  shelter               Shelter         @relation(fields: [shelterID], references: [id])

  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@index([status])
  @@map("pa_adoptions")
}

enum PetSize {
  Small
  Medium
  Large
}
enum PetGender {
  Male
  Female
}

enum AdoptionStatus {
  Pending
  Approved
  Rejected
  Withdrawn
}

enum UserType {
  User
  Shelter
}
