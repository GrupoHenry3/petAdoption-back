generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                    String          @id @default(cuid(2))
  email                 String          @unique
  password              String          @unique
  googleID              String?         @unique @map("google_id")
  fullName              String          @map("full_name")
  country               String?
  city                  String?
  address               String?
  phoneNumber           String?         @map("phone_number")
  avatarURL             String?         @map("avatar_url")
  userType              UserType        @default(User) @map("user_type")
  siteAdmin             Boolean         @default(false) @map("site_admin")
  isActive              Boolean         @default(true)  @map("is_active")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  shelter               Shelter?
  favoritePets          FavoritePets[]
  adoptions             Adoption[]
  donations             Donation[]

  @@index([id, email])
  @@map("pa_users")
}

model FavoritePets {
  id                    String          @id @default(cuid(2))
  userID                String          @map("user_id")
  user                  User            @relation(fields: [userID], references: [id])
  petID                 String          @map("pet_id")
  pet                   Pet             @relation(fields: [petID], references: [id])
  createdAt             DateTime        @default(now()) @map("created_at")

  @@index([userID, petID])
  @@map("pa_user_favorites")
}

model Shelter {
  id                    String          @id @default(cuid(2))
  name                  String
  country               String
  state                 String
  city                  String
  address               String
  phoneNumber           String          @map("phone_number")
  website               String?
  description           String?
  isVerified            Boolean         @default(false) @map("is_verified")
  isActive              Boolean         @default(true)  @map("is_active")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  userID                String          @unique @map("user_id")
  user                  User            @relation(fields: [userID], references: [id])
  pets                  Pet[]
  adoptions             Adoption[]
  donations             Donation[]

  @@index([name, country, city, state])
  @@map("pa_shelters")
}

model Pet {
  id                    String          @id @default(cuid(2))
  name                  String
  age                   Int
  gender                PetGender       @default(Male)
  size                  PetSize         @default(Small)
  adoptionFee           Int             @map("adoption_fee")
  avatarURL             String          @map("avatar_url")
  neutered              Boolean?        @default(false)
  trained               Boolean?        @default(false)
  vaccinated            Boolean?        @default(false)
  goodWithKids          Boolean?        @default(false) @map("good_with_kids")
  goodWithPets          Boolean?        @default(false) @map("good_with_pets")
  isAdopted             Boolean         @default(false) @map("is_adopted")
  isActive              Boolean         @default(true)  @map("is_active")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  shelterID             String          @map("shelter_id")
  shelter               Shelter         @relation(fields: [shelterID], references: [id])
  breedID               String          @map("breed_id")
  breed                 PetBreed        @relation(fields: [breedID], references: [id])
  speciesID             String          @map("species_id")
  species               PetSpecies      @relation(fields: [speciesID], references: [id])
  favorites             FavoritePets[]
  photos                PetPhotos[]
  adoption              Adoption?

  @@index([name, gender, size, breedID, speciesID])
  @@map("pa_pets")
}

model PetPhotos {
  id                    String          @id @default(cuid(2))
  image_url             String
  createdAt             DateTime        @default(now()) @map("created_at")

  petID                 String          @map("pet_id")
  pet                   Pet             @relation(fields: [petID], references: [id])

  @@index([petID])
  @@map("pa_pet_photos")
}

model PetBreed {
  id                    String          @id @default(cuid(2))
  name                  String
  description           String
  avatarURL             String?         @map("avatar_url")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt

  pets                  Pet[]
  speciesID             String          @map("species_id")
  species               PetSpecies      @relation(fields: [speciesID], references: [id])

  @@index([name])
  @@map("pa_pet_breeds")
}

model PetSpecies {
  id                    String          @id @default(cuid(2))
  name                  String          @unique
  createdAt             DateTime        @default(now()) @map("created_at")

  pets                  Pet[]
  breeds                PetBreed[]

  @@map("pa_pet_species")
}

model Adoption {
  id                    String          @id @default(cuid(2))
  dni                   String
  birthdate             String
  mainReason            String          @map("main_reason")
  expectatives          String
  previousPetExp        previousPetExp  @default(None) @map("previous_pet_experience")
  houseType             houseType       @default(House) @map("house_type")
  houseOwnership        houseOwnership  @default(Owned) @map("house_ownership")
  houseOuterSpace       houseOuterSpace @default(None) @map("house_outher_space")
  houseMembers          String          @map("house_members")
  livingSpace           String          @map("living_space")
  workingHours          String          @map("working_hours")
  dailyRoutine          String          @map("daily_routine")
  houseKidsAges         String?         @map("house_kids_ages")
  houseCurrentPets      String?         @map("house_current_pets")
  dailyExcercise        String?         @map("daily_excercise")
  travelFrequency       String?         @map("travel_frequency")
  petHistory            String?         @map("pet_history")
  additionalInfo        String?         @map("additional_information")
  status                AdoptionStatus  @default(Pending)
  rejectionReason       String?         @map("rejection_reason")
  isActive              Boolean         @default(true) @map("is_active")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  userID                String          @map("user_id")
  user                  User            @relation(fields: [userID], references: [id])
  shelterID             String          @map("shelter_id")
  shelter               Shelter         @relation(fields: [shelterID], references: [id])
  petID                 String          @unique @map("pet_id")
  pet                   Pet             @relation(fields: [petID], references: [id])

  @@index([status, userID, shelterID])
  @@map("pa_adoptions")
}

model Donation {
  id                    String          @id @default(cuid(2))
  amount                Int
  message               String?
  sessionID             String          @map("session_id")
  status                donationStatus  @default(pending)

  userID                String          @map("user_id")
  user                  User            @relation(fields: [userID], references: [id])
  shelterID             String          @map("shelter_id")
  shelter               Shelter         @relation(fields: [shelterID], references: [id])
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@index([userID])
  @@map("pa_user_donations")
}

enum UserType {
  User
  Shelter
}

enum PetSize {
  Small
  Medium
  Large
}
enum PetGender {
  Male
  Female
}

enum AdoptionStatus {
  Pending
  Approved
  Rejected
  Withdrawn
}

enum previousPetExp {
  None
  Basic
  Moderate
  Experienced
}

enum houseOwnership {
  Owned
  Rented
}

enum houseType {
  House
  Apartment
  Farm
}

enum houseOuterSpace {
  None
  Small
  Medium
  Large
}

enum donationStatus {
  pending
  completed
  failed
  expired
}
