datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

enum UserType {
  USER
  SHELTER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  googleID  String?  @map("google_id")
  fullName  String?  @map("full_name")
  phone     String?  
  address   String?  
  country   String?
  city      String?
  avatarURL String?  @map("avatar_url")
  userType  UserType @default(USER) @map("user_type")
  siteAdmin Boolean  @default(false) @map("site_admin")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shelter      Shelter?
  favoritePets FavoritePets[]
  adoptions    Adoption[]

  @@index([id, email])
  @@map("pa_users")
}

model Shelter {
  id          String   @id @default(cuid())
  name        String
  country     String
  state       String
  city        String
  address     String
  phoneNumber String   @map("phone_number")
  website     String
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userID  String   @unique @map("user_id")
  user    User     @relation(fields: [userID], references: [id])
  pets    Pet[]
  adoptions Adoption[]

  @@index([name, country, city, state])
  @@map("pa_shelters")
}

model FavoritePets {
  id        String   @id @default(cuid())
  userID    String
  user      User     @relation(fields: [userID], references: [id])
  petID     String
  pet       Pet      @relation(fields: [petID], references: [id])
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userID, petID])
  @@map("pa_user_favorites")
}

model Pet {
  id          String     @id @default(cuid())
  name        String
  age         Int
  gender      PetGender  @default(Male)
  size        PetSize    @default(Small)
  adoptionFee Int
  isAdopted   Boolean    @default(false) @map("is_adopted")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  shelterID   String
  shelter     Shelter    @relation(fields: [shelterID], references: [id])
  breedID     String
  breed       PetBreed   @relation(fields: [breedID], references: [id])
  speciesID   String
  species     PetSpecies @relation(fields: [speciesID], references: [id])
  adoptionID  String?    
  adoption    Adoption?  @relation(fields: [adoptionID], references: [id])
  favorites   FavoritePets[]

  @@index([name, gender, size, breedID, speciesID])
  @@map("pa_pets")
}

model PetBreed {
  id        String     @id @default(cuid())
  name      String
  description String
  avatarURL String?    @map("avatar_url")
  createdAt DateTime   @default(now()) @map("created_at")

  pets      Pet[]
  speciesID String
  species   PetSpecies @relation(fields: [speciesID], references: [id])

  @@index([name])
  @@map("pa_pet_breeds")
}

model PetSpecies {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")

  pets      Pet[]
  breeds    PetBreed[]

  @@map("pa_pet_species")
}

model Adoption {
  id              String         @id @default(cuid())
  questions       Json?
  status          AdoptionStatus @default(Pending)
  rejectionStatus String?
  pets            Pet[]

  userID    String
  user      User    @relation(fields: [userID], references: [id])
  shelterID String
  shelter   Shelter @relation(fields: [shelterID], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("pa_adoptions")
}

enum PetSize {
  Small
  Medium
  Large
}

enum PetGender {
  Male
  Female
}

enum AdoptionStatus {
  Pending
  Approved
  Rejected
  Withdrawn
}
