<html>
  <head>
    <style>
      :root {
        --color-accent: rgba(0, 201, 80, 1);
        --color-background: rgba(255, 255, 255, 1);
        --color-background-muted: rgba(250, 250, 250, 1);
        --color-foreground: rgba(34, 34, 34, 1);
        --color-foreground-muted: rgba(0, 0, 0, 0.5);
        --color-border: rgba(237, 237, 237, 1);
      }

      body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background: #fafafa;
        color: #0a0a0a;
      }

      .table {
        text-align: left;
        padding: 0;
        margin: 0;
        border: 0;
        min-width: 480px;
        width: 100%;
        background: #fafafa;
      }

      .topline {
        height: 2px;
        background: #00c950;
      }

      .container {
        text-align: left;
        background: #fff;
        max-width: 500px;
        margin: 0 auto;
        padding: 24px;
        border: 1px solid #ededed;
      }

      h1 {
        font-size: 18px;
        margin-bottom: 16px;
      }

      p {
        margin: 0;
        color: #9e9e9e;
        line-height: 1.5;
      }

      p:not(:last-of-type) {
        margin-bottom: 12px;
      }

      a {
        color: #00c950;
        text-decoration: underline;
      }

      .button {
        margin-top: 24px;
        display: inline-block;
        border: 0;
        background: #00c950;
        color: #ffffff;
        border-radius: 4px;
        padding: 12px 32px;
        cursor: pointer;
        font-weight: bold;
        text-decoration: none;
      }

      .header {
        padding: 24px 0;
        text-align: center;
      }

      .header > img {
        border-radius: 4px;
      }

      .footer {
        padding: 24px 0;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <table class='table'>
      <tbody>
        <tr>
          <td class='topline'></td>
        </tr>
        <tr>
          <td class='header'>
            <img alt='logo' src='https://i.imgur.com/Lp4051N.jpeg' height='64' width='64' />
          </td>
        </tr>
        <tr>
          <td>
            <div class='container'>
              <h1>Dear, {{shelterName}} staff</h1>
              <p>A new adoption application has been submitted through our website. </p>
              <p>Please review the application and contact the adopter to schedule a meeting or
                proceed with the next steps in the adoption process.</p>
              <a href='/{{requestId}}' class='button'>Review application</a>
            </div>
          </td>
        </tr>
        <tr>
          <td class='footer'></td>
        </tr>
      </tbody>
    </table>
  </body>
</html>