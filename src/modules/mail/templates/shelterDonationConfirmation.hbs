<html>
  <head>
    <style>
      :root {
        --color-accent: rgba(0, 201, 80, 1);
        --color-background: rgba(255, 255, 255, 1);
        --color-background-muted: rgba(250, 250, 250, 1);
        --color-foreground: rgba(34, 34, 34, 1);
        --color-foreground-muted: rgba(0, 0, 0, 0.5);
        --color-border: rgba(237, 237, 237, 1);
      }

      body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background: #fafafa;
        color: #0a0a0a;
      }

      .table {
        text-align: left;
        padding: 0;
        margin: 0;
        border: 0;
        min-width: 480px;
        width: 100%;
        background: #fafafa;
      }

      .topline {
        height: 2px;
        background: #00c950;
      }

      .container {
        text-align: left;
        background: #fff;
        max-width: 500px;
        margin: 0 auto;
        padding: 24px;
        border: 1px solid #ededed;
      }

      h1 {
        font-size: 18px;
        margin-bottom: 12px;
      }

      p {
        margin: 0;
        color: #9e9e9e;
        line-height: 1.5;
      }

      p:not(:last-of-type) {
        margin-bottom: 20px;
      }

      .button {
        margin-top: 24px;
        display: inline-block;
        border: 0;
        background: #00c950;
        color: #ffffff;
        border-radius: 4px;
        padding: 12px 32px;
        cursor: pointer;
        font-weight: bold;
        text-decoration: none;
      }

      .header {
        padding: 24px 0;
        text-align: center;
      }

      .header > img {
        border-radius: 4px;
      }

      .footer {
        padding: 24px 0;
        text-align: center;
      }

      .content {
        text-align: left;
        background: #f3f3f5;
        max-width: 95%;
        margin: 0 auto;
        padding: 12px;
        margin-top: 12px;
      }

      .content p {
        margin: 0;
      }

      .content p:not(:last-of-type) {
        margin-bottom: 6px;
      }

      .content p b {
        color: #717182;
      }

      .preheader {
        color: transparent;
        display: none;
        height: 0;
        max-height: 0;
        max-width: 0;
        opacity: 0;
        overflow: hidden;
        mso-hide: all;
        visibility: hidden;
        width: 0;
      }
    </style>
  </head>
  <body>
    <p class='preheader'>You've received a new donation.</p>
    <table class='table'>
      <td>&nbsp;</td>
      <tbody>
        <tr>
          <td class='topline'></td>
        </tr>
        <tr>
          <td class='header'>
            <img alt='logo' src='https://i.imgur.com/Lp4051N.jpeg' height='64' width='64' />
          </td>
        </tr>
        <tr>
          <td>
            <div class='container'>
              <h1>Dear, {{shelterName}} staff</h1>
              <p>Your shelter has received a donation through our website.</p>
              <div class='content'>
                <p><b>From:</b> <span>{{userName}}</span></p>
                <p><b>Amount:</b> <span>${{donationAmount}}</span></p>
                {{#if donationMessage}}
                  <p><b>Message:</b> <span>{{donationMessage}}</span></p>
                {{/if}}
              </div>
              <a href='/{{donationId}}' class='button'>View donation</a>
            </div>
          </td>
        </tr>
        <tr>
          <td class='footer'></td>
        </tr>
      </tbody>
    </table>
  </body>
</html>