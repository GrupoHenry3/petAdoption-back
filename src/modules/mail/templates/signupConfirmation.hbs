<html>
  <head>
    <style>
      body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background: #fafafa;
        color: #0a0a0a;
      }

      .table {
        text-align: left;
        padding: 0;
        margin: 0;
        border: 0;
        min-width: 480px;
        width: 100%;
        background: #fafafa;
      }

      .topline {
        height: 2px;
        background: #00c950;
      }

      .container {
        background: #fff;
        max-width: 500px;
        margin: 0 auto;
        padding: 24px;
        border: 1px solid #ededed;
        text-align: left;
      }

      h1 {
        font-size: 18px;
        margin-bottom: 16px;
      }

      p {
        margin: 0;
        color: #9e9e9e;
      }

      p:not(:last-of-type) {
        margin-bottom: 12px;
      }

      a {
        color: #00c950;
      }

      .button {
        margin-top: 24px;
        display: inline-block;
        border: 0;
        background: #00c950;
        color: #ffffff;
        border-radius: 4px;
        padding: 12px 32px;
        cursor: pointer;
        font-weight: bold;
        text-decoration: none;
      }

      .header {
        padding: 24px 0;
        text-align: center;
      }

      .header > img {
        border-radius: 4px;
      }

      .footer {
        padding: 24px 0;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <table class='table'>
      <tbody>
        <tr>
          <td class='topline'></td>
        </tr>
        <tr>
          <td class='header'>
            <img alt='logo' src='https://i.imgur.com/Lp4051N.jpeg' height='64' width='64' />
          </td>
        </tr>
        <tr>
          <td>
            <div class='container'>
              <h1>Hi, {{userName}}</h1>
              <p>Thanks for signing up for Pet Adoption. We're very excited to have you on board.</p>
              <p>To get started, please sign in clicking the button below.</p>
              <a href='/' class='button'>Sign In</a>
            </div>
          </td>
        </tr>
        <tr>
          <td class='footer'>
            <p>You're receiveing this email because of your account on
              <a href='/'>Pet Adoption</a>.</p>
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>